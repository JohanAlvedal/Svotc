###############################################################################
##  SVOTC – 40_notify.yaml
##  @2.0.0-beta
##
##  All notifications and system logging.
##  Triggers on health/schema/freeze state changes and guard disable events.
##  Uses choose with specific trigger conditions — order matters.
###############################################################################

automation:
  #########################################################################
  ## @40.N.0 Main notify hub (existing)
  #########################################################################
  - alias: "SVOTC Notify"
    id: svotc_notify_all
    mode: single
    trigger:
      # Inputs or price go bad (3 min grace before alerting)
      - platform: state
        entity_id: binary_sensor.svotc_inputs_healthy
        to: "off"
        for: "00:03:00"
      - platform: state
        entity_id: binary_sensor.svotc_price_available
        to: "off"
        for: "00:03:00"

      # Recovery (wait 2 min to confirm stable)
      - platform: template
        for: "00:02:00"
        value_template: >
          {{ is_state('binary_sensor.svotc_inputs_healthy','on')
             and is_state('binary_sensor.svotc_price_available','on') }}

      # Comfort guard disabled (5 min — user may have toggled by accident)
      - platform: state
        entity_id: input_boolean.svotc_comfort_guard_enabled
        to: "off"
        for: "00:05:00"

      # Freeze reason codes: enter and exit
      - platform: state
        entity_id: input_text.svotc_reason_code
        to: "PRICE_DATA_FREEZE"
      - platform: state
        entity_id: input_text.svotc_reason_code
        from: "PRICE_DATA_FREEZE"
      - platform: state
        entity_id: input_text.svotc_reason_code
        to: "MISSING_INPUTS_FREEZE"
      - platform: state
        entity_id: input_text.svotc_reason_code
        from: "MISSING_INPUTS_FREEZE"
      - platform: state
        entity_id: input_text.svotc_reason_code
        to: "PRICE_SCHEMA_INVALID"
      - platform: state
        entity_id: input_text.svotc_reason_code
        from: "PRICE_SCHEMA_INVALID"

      # Freeze stuck while braking (5 min — offset may be stranded positive)
      - platform: template
        for: "00:05:00"
        value_template: >
          {{ is_state('input_text.svotc_reason_code','PRICE_DATA_FREEZE')
             and (states('input_number.svotc_applied_offset_c') | float(0)) > 0.5
             and is_state('input_boolean.svotc_freeze_notified','off') }}

    action:
      - variables:
          # notify action:
          # - If input_text is "Notiser" => notify.notiser
          # - If input_text is "notify.mobile_app_xxx" => uses it directly
          # - Fallback => notify.notify
          notify_svc: >-
            {% set raw = states('input_text.svotc_notify_service') | trim %}
            {% if raw in ['unknown','unavailable','none',''] %}
              notify.notify
            {% elif '.' in raw %}
              {{ raw }}
            {% else %}
              notify.{{ raw | lower | replace(' ', '_') }}
            {% endif %}

          indoor_map: "{{ states('input_text.svotc_entity_indoor') }}"
          outdoor_map: "{{ states('input_text.svotc_entity_outdoor') }}"
          price_map: "{{ states('input_text.svotc_entity_price') }}"

          src_indoor: "{{ states('sensor.svotc_src_indoor') }}"
          src_outdoor: "{{ states('sensor.svotc_src_outdoor') }}"
          src_price: "{{ states('sensor.svotc_src_current_price') }}"

          inputs_ok: "{{ is_state('binary_sensor.svotc_inputs_healthy','on') }}"
          price_ok: "{{ is_state('binary_sensor.svotc_price_available','on') }}"
          schema_ok: "{{ is_state('binary_sensor.svotc_price_schema_ok','on') }}"
          guard_enabled: "{{ is_state('input_boolean.svotc_comfort_guard_enabled','on') }}"
          reason: "{{ states('input_text.svotc_reason_code') }}"

          missing_list: >
            {% set miss = [] %}
            {% if indoor_map  in ['unknown','unavailable',''] %}{% set miss = miss + ['indoor mapping'] %}{% endif %}
            {% if outdoor_map in ['unknown','unavailable',''] %}{% set miss = miss + ['outdoor mapping'] %}{% endif %}
            {% if price_map   in ['unknown','unavailable',''] %}{% set miss = miss + ['price mapping'] %}{% endif %}
            {% if not schema_ok %}{% set miss = miss + ['price schema (raw_today format)'] %}{% endif %}
            {{ miss | join(', ') if miss | length > 0 else 'none' }}

          snapshot: >
            reason={{ reason }}, mode={{ states('input_select.svotc_mode') }},
            guard={{ is_state('binary_sensor.svotc_comfort_guard_active','on') }},
            indoor={{ src_indoor }}°C (map={{ indoor_map }}),
            outdoor={{ src_outdoor }}°C (map={{ outdoor_map }}),
            price={{ src_price }} SEK/kWh (map={{ price_map }}),
            schema_ok={{ schema_ok }}, price_ok={{ price_ok }},
            p30={{ states('sensor.svotc_p30') }}, p80={{ states('sensor.svotc_p80') }},
            ttn={{ states('sensor.svotc_minutes_to_next_brake_start') }} min,
            applied={{ states('input_number.svotc_applied_offset_c') }}°C

      - choose:
          # ── Freeze: log entry to system_log ─────────────────────────────
          - conditions: >
              {{ trigger.entity_id == 'input_text.svotc_reason_code'
                 and trigger.to_state is not none
                 and trigger.to_state.state in
                     ['MISSING_INPUTS_FREEZE','PRICE_SCHEMA_INVALID','PRICE_DATA_FREEZE'] }}
            sequence:
              - action: system_log.write
                data:
                  level: warning
                  logger: homeassistant.components.automation.svotc
                  message: "SVOTC FREEZE START: {{ trigger.to_state.state }} | {{ snapshot }}"
              - choose:
                  - conditions: "{{ trigger.to_state.state == 'PRICE_DATA_FREEZE' }}"
                    sequence:
                      - action: input_datetime.set_datetime
                        target: { entity_id: input_datetime.svotc_freeze_since }
                        data:
                          {
                            datetime: "{{ now().strftime('%Y-%m-%d %H:%M:%S') }}",
                          }
                      - action: input_boolean.turn_off
                        target:
                          { entity_id: input_boolean.svotc_freeze_notified }
              - stop: "Freeze entry logged"

          # ── Freeze: log exit ─────────────────────────────────────────────
          - conditions: >
              {{ trigger.entity_id == 'input_text.svotc_reason_code'
                 and trigger.from_state is not none
                 and trigger.from_state.state in
                     ['MISSING_INPUTS_FREEZE','PRICE_SCHEMA_INVALID','PRICE_DATA_FREEZE'] }}
            sequence:
              - action: system_log.write
                data:
                  level: info
                  logger: homeassistant.components.automation.svotc
                  message: >
                    SVOTC FREEZE END: from={{ trigger.from_state.state }}
                    to={{ states('input_text.svotc_reason_code') }} | {{ snapshot }}
              - action: input_boolean.turn_off
                target: { entity_id: input_boolean.svotc_freeze_notified }
              - stop: "Freeze exit logged"

          # ── Freeze stuck-brake notification ──────────────────────────────
          - conditions: >
              {{ trigger.platform == 'template'
                 and is_state('input_text.svotc_reason_code','PRICE_DATA_FREEZE')
                 and (states('input_number.svotc_applied_offset_c') | float(0)) > 0.5
                 and is_state('input_boolean.svotc_freeze_notified','off') }}
            sequence:
              - action: "{{ notify_svc }}"
                data:
                  title: "SVOTC: Price freeze — braking stuck"
                  message: >
                    PRICE_DATA_FREEZE has been active for 5+ minutes while
                    a positive offset is applied.

                    Freeze since: {{ states('input_datetime.svotc_freeze_since') }}
                    Applied offset: {{ states('input_number.svotc_applied_offset_c') }}°C

                    SVOTC is ramping the positive offset down toward 0 at
                    max_delta/tick to avoid getting stranded in brake mode.

                    Snapshot: {{ snapshot }}
              - action: input_boolean.turn_on
                target: { entity_id: input_boolean.svotc_freeze_notified }
              - stop: "Freeze stuck-brake notified"

          # ── Comfort guard disabled ───────────────────────────────────────
          - conditions: >
              {{ trigger.entity_id == 'input_boolean.svotc_comfort_guard_enabled'
                 and not guard_enabled }}
            sequence:
              - action: "{{ notify_svc }}"
                data:
                  title: "SVOTC: Comfort guard is OFF"
                  message: >
                    Comfort guard has been disabled for at least 5 minutes.
                    Indoor temperature will not be protected during braking.

                    Current: mode={{ states('input_select.svotc_mode') }},
                    indoor={{ src_indoor }}°C
                    (target={{ states('sensor.svotc_dynamic_target_temperature') }}°C)
              - stop: "Guard-off notified"

          # ── Missing inputs or price data ─────────────────────────────────
          - conditions: "{{ not inputs_ok or not price_ok }}"
            sequence:
              - action: "{{ notify_svc }}"
                data:
                  title: "SVOTC: Missing data (3+ minutes)"
                  message: >
                    inputs_healthy={{ inputs_ok }},
                    price_available={{ price_ok }},
                    price_schema_ok={{ schema_ok }}

                    Missing: {{ missing_list }}

                    Mapping:
                      indoor={{ indoor_map }},
                      outdoor={{ outdoor_map }},
                      price={{ price_map }}

                    Sources:
                      indoor={{ src_indoor }},
                      outdoor={{ src_outdoor }},
                      price={{ src_price }}
              - stop: "Missing-data notified"

          # ── Recovery ─────────────────────────────────────────────────────
          - conditions: >
              {{ inputs_ok and price_ok
                 and trigger.platform == 'template'
                 and not is_state('input_text.svotc_reason_code','PRICE_DATA_FREEZE') }}
            sequence:
              - action: "{{ notify_svc }}"
                data:
                  title: "SVOTC: All data OK again"
                  message: >
                    Inputs and price data have been healthy for 2+ minutes.
                    Normal operation resumed. reason={{ reason }}
              - stop: "Recovery notified"

  #########################################################################
  ## @40.N.1 Auto PassThrough (stabil + peak-check)
  ## - Kräver stabilt läge i 20 min (anti-fladder)
  ## - Byter bara om kommande peak (12h) är < 0.60 SEK/kWh
  ## - Byter aldrig under prebrake/brake
  ## - Kräver inputs_ok + price_ok + schema_ok (annars ingen auto-ändring)
  #########################################################################
  - id: svotc_auto_passthrough_warm_or_supercheap
    alias: "SVOTC: Auto PassThrough (stabil + peak-check)"
    mode: single
    trigger:
      - platform: template
        for: "00:20:00"
        value_template: >
          {% set mode = states('input_select.svotc_mode') %}
          {% set outdoor = states('sensor.svotc_src_outdoor') | float(0) %}
          {% set price = states('sensor.svotc_src_current_price') | float(999) %}
          {% set p30 = states('sensor.svotc_p30') | float(999) %}
          {% set phase = states('input_text.svotc_brake_phase') %}
          {% set pre = states('sensor.svotc_prebrake_strength') | float(0) %}

          {% set inputs_ok = is_state('binary_sensor.svotc_inputs_healthy','on') %}
          {% set price_ok  = is_state('binary_sensor.svotc_price_available','on') %}
          {% set schema_ok = is_state('binary_sensor.svotc_price_schema_ok','on') %}

          {% set summer = outdoor >= 14.0 %}
          {% set supercheap = price <= (p30 * 0.85) %}

          {# Peak-check nästa 12h #}
          {% set ent = states('input_text.svotc_entity_price') | trim %}
          {% set now_ts = as_timestamp(now()) %}
          {% set horizon_ts = now_ts + (12 * 3600) %}
          {% set blocks = (state_attr(ent,'raw_today') | default([], true))
                          + (state_attr(ent,'raw_tomorrow') | default([], true)) %}
          {% set ns = namespace(mx=none) %}
          {% for it in blocks %}
            {% if it is mapping %}
              {% set s = as_timestamp(it.get('start'), none) %}
              {% set v = it.get('value') | float(none) %}
              {% if s is not none and v is not none and s >= now_ts and s <= horizon_ts %}
                {% if ns.mx is none or v > ns.mx %}{% set ns.mx = v %}{% endif %}
              {% endif %}
            {% endif %}
          {% endfor %}
          {% set peak = ns.mx if ns.mx is not none else 0 %}
          {% set peak_expensive = peak >= 0.60 %}

          {{ mode == 'Smart'
             and (summer or supercheap)
             and not peak_expensive
             and inputs_ok and price_ok and schema_ok
             and pre == 0
             and phase in ['idle','ramping_down'] }}

    action:
      - variables:
          notify_svc: >-
            {% set raw = states('input_text.svotc_notify_service') | trim %}
            {% if raw in ['unknown','unavailable','none',''] %}
              notify.notify
            {% elif '.' in raw %}
              {{ raw }}
            {% else %}
              notify.{{ raw | lower | replace(' ', '_') }}
            {% endif %}

          outdoor: "{{ states('sensor.svotc_src_outdoor') | float(0) }}"
          price: "{{ states('sensor.svotc_src_current_price') | float(999) }}"
          p30: "{{ states('sensor.svotc_p30') | float(999) }}"

          reason: >-
            {% set summer = outdoor >= 14.0 %}
            {% if summer %}
              Varmt ute ({{ outdoor|round(1) }}°C)
            {% else %}
              Superbilligt ({{ price|round(3) }} ≤ {{ (p30*0.85)|round(3) }})
            {% endif %}

      - action: "{{ notify_svc }}"
        data:
          title: "SVOTC: Auto PassThrough"
          message: >-
            ✅ Växlar till PassThrough (stabilt i 20 min).
            Orsak: {{ reason }}.
            Peak-check: inga priser ≥ 0.60 SEK/kWh inom 12h.

      - action: input_select.select_option
        target:
          entity_id: input_select.svotc_mode
        data:
          option: "PassThrough"

  #########################################################################
  ## @40.N.2 Auto tillbaka till Smart (stabil)
  ## - Kräver normal-läge i 30 min (anti-fladder)
  ## - Kräver inputs_ok + price_ok + schema_ok
  #########################################################################
  - id: svotc_auto_return_to_smart_when_normal
    alias: "SVOTC: Auto tillbaka till Smart (stabil)"
    mode: single
    trigger:
      - platform: template
        for: "00:30:00"
        value_template: >
          {% set mode = states('input_select.svotc_mode') %}
          {% set outdoor = states('sensor.svotc_src_outdoor') | float(0) %}
          {% set price = states('sensor.svotc_src_current_price') | float(999) %}
          {% set p30 = states('sensor.svotc_p30') | float(999) %}

          {% set inputs_ok = is_state('binary_sensor.svotc_inputs_healthy','on') %}
          {% set price_ok  = is_state('binary_sensor.svotc_price_available','on') %}
          {% set schema_ok = is_state('binary_sensor.svotc_price_schema_ok','on') %}

          {% set summer = outdoor >= 14.0 %}
          {% set supercheap = price <= (p30 * 0.85) %}

          {{ mode == 'PassThrough'
             and (not summer) and (not supercheap)
             and inputs_ok and price_ok and schema_ok }}

    action:
      - variables:
          notify_svc: >-
            {% set raw = states('input_text.svotc_notify_service') | trim %}
            {% if raw in ['unknown','unavailable','none',''] %}
              notify.notify
            {% elif '.' in raw %}
              {{ raw }}
            {% else %}
              notify.{{ raw | lower | replace(' ', '_') }}
            {% endif %}

          outdoor: "{{ states('sensor.svotc_src_outdoor') | float(0) }}"
          price: "{{ states('sensor.svotc_src_current_price') | float(999) }}"

      - action: input_select.select_option
        target:
          entity_id: input_select.svotc_mode
        data:
          option: "Smart"

      - action: "{{ notify_svc }}"
        data:
          title: "SVOTC: Smart igen"
          message: >-
            ✅ Tillbaka till Smart (normal-läge stabilt i 30 min).
            Ute: {{ outdoor|round(1) }}°C, pris: {{ price|round(3) }} SEK/kWh.
